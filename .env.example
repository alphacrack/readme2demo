# Copy to `.env` (gitignored) and fill in the auth you use. You need ONE of the
# Claude options below. Do NOT commit real secrets.

# Option A — run on your Claude subscription (no API key), self-hosted single
# operator. Create the token with `claude setup-token` and paste it here.
# (Copy the printed sk-ant-oat01-... value; do not use $(claude setup-token).)
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Option B — metered API billing (scale, concurrency, or hosting for others).
# ANTHROPIC_API_KEY=sk-ant-...

# Optional — only for the experimental OpenHands engine (--engine openhands)
# LLM_API_KEY=...
# LLM_MODEL=...
