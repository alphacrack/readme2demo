# readme2demo configuration — copy to `readme2demo.toml` and edit.
# Precedence: CLI flags > readme2demo.toml > built-in defaults.
# (readme2demo.toml is gitignored; this .example file is the tracked template.)

# --- Agent engine -----------------------------------------------------------
engine = "claude-code"        # or "openhands" (experimental; the provider
                              # presets --gemini / --openai / --anthropic use it)
model = "claude-sonnet-5"     # model for planner / distiller / tutorial passes
llm_backend = "auto"          # auto | api | claude-cli | gemini | openai
                              # (the presets pick the matching one)
max_turns = 60
agent_timeout_s = 1500
budget_usd = 5.0              # abort a run if the agent exceeds this

# --- Sandbox ----------------------------------------------------------------
base_image = "readme2demo/base:latest"
                              # --engine openhands and the provider presets
                              # default to readme2demo/openhands:latest when
                              # this is unset (build it:
                              # docker build -t readme2demo/openhands:latest images/openhands)
network = "bridge"
memory = "4g"
cpus = "2"
pids_limit = 512
# SECURITY TRADEOFF — off by default. Mounts the host Docker socket into the
# sandbox so demos that manage containers work. This pierces isolation; only
# enable for repos you trust.
allow_docker_socket = false

# --- Stages -----------------------------------------------------------------
dry_run = false               # stop after ingest/planning (feasibility verdict only)
verify_timeout_s = 900
verify_retries = 1
distill_retries = 1
skip_video = false

# --- Layout -----------------------------------------------------------------
runs_dir = "runs"
